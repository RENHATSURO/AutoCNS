	autoWalkBtn.Text = autoWalkIfIdleEnabled and "Auto Walk If Idle: ON" or "Auto Walk If Idle: OFF"
end)

autoJumpBtn.MouseButton1Click:Connect(function()
	autoJumpEnabled = not autoJumpEnabled
	autoJumpBtn.Text = autoJumpEnabled and "Auto Jump: ON" or "Auto Jump: OFF"
end)

local draggingSpeed = false
local draggingDelay = false

speedBar.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSpeed = true
	end
end)

delayBar.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingDelay = true
	end
end)

UserInputService.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSpeed = false
		draggingDelay = false
	end
end)

RunService.RenderStepped:Connect(function()
	if not scriptEnabled then
		return
	end
	if draggingSpeed then
		local m = player:GetMouse()
		local x = math.clamp((m.X - speedBar.AbsolutePosition.X) / speedBar.AbsoluteSize.X, 0, 1)
		speedFill.Size = UDim2.fromScale(x, 1)
		tweenSpeed = math.floor(5 + x * 45)
		speedLabel.Text = "Tween Speed: " .. tweenSpeed
	end
	if draggingDelay then
		local m = player:GetMouse()
		local x = math.clamp((m.X - delayBar.AbsolutePosition.X) / delayBar.AbsoluteSize.X, 0, 1)
		delayFill.Size = UDim2.fromScale(x, 1)
		postCollectDelay = math.floor(x * 2 * 100) / 100
		delayLabel.Text = string.format("Delay: %.2fs", postCollectDelay)
	end
end)

minBtn.MouseButton1Click:Connect(function()
	setMinimized(not isMinimized)
end)

hideBtn.MouseButton1Click:Connect(function()
	hideMainToTiny()
end)

tinyToggle.MouseButton1Click:Connect(function()
	showMainFromTiny()
end)

local function shutdownScript()
	scriptEnabled = false
	autoFarm = false
	autoJumpEnabled = false
	autoWalkIfIdleEnabled = false
	if activeTween then
		activeTween:Cancel()
	end
	gui.Enabled = false
end

killBtn.MouseButton1Click:Connect(function()
	confirm.Visible = true
end)

noBtn.MouseButton1Click:Connect(function()
	confirm.Visible = false
end)

yesBtn.MouseButton1Click:Connect(function()
	confirm.Visible = false
	shutdownScript()
end)

-- ================= STATS LOOP =================
local startTime = os.clock()
task.spawn(function()
	while scriptEnabled do
		deathLabel.Text = "Deaths: " .. tostring(deathCount)
		local elapsed = math.floor(os.clock() - startTime)
		local h = math.floor(elapsed / 3600)
		local m = math.floor((elapsed % 3600) / 60)
		local s = elapsed % 60
		uptimeLabel.Text = string.format("Uptime: %02d:%02d:%02d", h, m, s)
		task.wait(1)
	end
end)

-- ================= STATS/COINS LIST LOOP (kept lightweight) =================
task.spawn(function()
	while scriptEnabled do
		refreshCoins()
		task.wait(listRefreshInterval)
	end
end)
